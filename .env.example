# Copy to .env and fill in. Both APIs are free-tier.

# EIA Open Data (WTI spot driver) — https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# FRED (rates / inflation / credit spreads) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Pinned data vintage for reproducible offline backtests (default: 2026-07).
FCE_DATA_VINTAGE=2026-07
